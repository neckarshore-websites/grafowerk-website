# Grafowerk website — environment variables
#
# Copy to `.env.local` and fill in to enable real contact-form delivery.
# Without these, the contact form runs in dry-run mode in development
# (logs the would-be mail + returns success) and returns an honest error
# in production (so the form never silently swallows messages).

# SMTP transport for the contact form (all six required to send mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Grafowerk Website <noreply@grafowerk.de>"
CONTACT_EMAIL_TO=info@grafowerk.de
